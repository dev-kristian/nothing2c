      onErrorChange?.("Failed to generate MoviesApi.Club URL.");
      return null;
    }
  }, [tmdbId, isTvShow, currentSeason, currentEpisode, onErrorChange]);

  useEffect(() => {
    const url = generateEmbedUrl();
    onUrlChange(url);
  }, [generateEmbedUrl, onUrlChange]);

  return null;
