                </>
              ) : (
                 <>
                  <p className="text-sm text-muted-foreground">{userData?.email || 'N/A'}</p>
                </>
              )}
            </div>
          </div>
        </div>
      </section>
  
      {hasPasswordProvider && (
        <section className="rounded-xl bg-card border shadow-sm overflow-hidden">
