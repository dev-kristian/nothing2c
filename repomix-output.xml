                    />
                    <StatRow
                      icon={Play}
                      label="Episodes"
                      value={episodes?.toString() || 'N/A'}
                    />
                  </>
                ) : (
                  <>
                    <StatRow
                      icon={Coins}
                      label="Budget"
                      value={budget && budget !== 0 ? formatNumber(budget) : 'N/A'}
                    />
                    <StatRow
                      icon={BarChart3}
                      label="Revenue"
                      value={revenue && revenue !== 0 ? formatNumber(revenue) : 'N/A'}
                    />
